# Supabase credentials (vind je in je Supabase dashboard > Settings > API)
SUPABASE_URL=https://jouw-project-id.supabase.co
SUPABASE_SERVICE_KEY=jouw-service-role-key-hier

# Supabase storage bucket waar de logo's naartoe gaan
SUPABASE_LOGO_BUCKET=club-logos

# Supabase tabel voor clubdata (maak deze aan of gebruik bestaande)
SUPABASE_CLUBS_TABLE=clubs
